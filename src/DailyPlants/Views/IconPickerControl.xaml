<UserControl
    x:Class="DailyPlants.Views.IconPickerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:DailyPlants.Helpers">
    <StackPanel Spacing="12">
        <TextBlock
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Style="{StaticResource CaptionTextBlockStyle}"
            Text="{helpers:Localize Key=CustomItemEditor_IconPickerCatalogLabel}" />

        <GridView
            x:Name="CatalogGrid"
            IsItemClickEnabled="False"
            ItemsSource="{x:Bind CatalogEntries, Mode=OneTime}"
            SelectionChanged="OnCatalogSelectionChanged"
            SelectionMode="Single">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="helpers:CustomIconCatalogEntry">
                    <Grid
                        Width="48"
                        Height="48"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                        <Image
                            Width="32"
                            Height="32"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <Image.Source>
                                <BitmapImage UriSource="{x:Bind Uri, Mode=OneTime}" />
                            </Image.Source>
                        </Image>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <TextBlock
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Style="{StaticResource CaptionTextBlockStyle}"
            Text="{helpers:Localize Key=CustomItemEditor_IconPickerEmojiLabel}" />

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="EmojiInputBox"
                Grid.Column="0"
                MaxLength="16"
                PlaceholderText="{helpers:Localize Key=CustomItemEditor_IconPickerEmojiPlaceholder}"
                TextChanged="OnEmojiInputTextChanged" />

            <Border
                Grid.Column="1"
                Width="48"
                Height="48"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8">
                <IconSourceElement
                    x:Name="PreviewIcon"
                    Width="28"
                    Height="28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />
            </Border>
        </Grid>
    </StackPanel>
</UserControl>
