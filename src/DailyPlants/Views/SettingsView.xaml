<Page x:Class="DailyPlants.Views.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:DailyPlants.Views"
      xmlns:helpers="using:DailyPlants.Helpers"
      xmlns:controls="using:CommunityToolkit.WinUI.Controls"
      NavigationCacheMode="Required">

    <ScrollViewer>
        <Grid>
            <StackPanel Spacing="4" Padding="16" HorizontalAlignment="Stretch">

                <TextBlock Text="{helpers:Localize Key=Nav_Settings}"
                           Style="{StaticResource TitleTextBlockStyle}"
                           Margin="0,0,0,16" />

                <!-- Checklists Section -->
                <TextBlock Text="{helpers:Localize Key=Settings_ActiveChecklists}"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           Margin="1,0,0,6" />

                <controls:SettingsExpander IsExpanded="True">
                    <controls:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE762;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </controls:SettingsExpander.HeaderIcon>
                    <controls:SettingsExpander.Header>
                        <TextBlock Text="{helpers:Localize Key=Settings_ActiveChecklists}" />
                    </controls:SettingsExpander.Header>
                    <controls:SettingsExpander.Description>
                        <TextBlock Text="{helpers:Localize Key=Settings_ActiveChecklistsDesc}" />
                    </controls:SettingsExpander.Description>

                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard>
                            <controls:SettingsCard.Header>
                                <TextBlock Text="{helpers:Localize Key=Settings_DailyDozen}" />
                            </controls:SettingsCard.Header>
                            <controls:SettingsCard.Description>
                                <TextBlock Text="{helpers:Localize Key=Settings_DailyDozenDesc}" TextWrapping="Wrap" />
                            </controls:SettingsCard.Description>
                            <ToggleSwitch IsOn="{Binding DailyDozenEnabled, Mode=TwoWay}"
                                          OnContent="{helpers:Localize Key=Settings_Enabled}"
                                          OffContent="{helpers:Localize Key=Settings_Disabled}" />
                        </controls:SettingsCard>

                        <controls:SettingsCard>
                            <controls:SettingsCard.Header>
                                <TextBlock Text="{helpers:Localize Key=Settings_TwentyOneTweaks}" />
                            </controls:SettingsCard.Header>
                            <controls:SettingsCard.Description>
                                <TextBlock Text="{helpers:Localize Key=Settings_TwentyOneTweaksDesc}" TextWrapping="Wrap" />
                            </controls:SettingsCard.Description>
                            <ToggleSwitch IsOn="{Binding TwentyOneTweaksEnabled, Mode=TwoWay}"
                                          OnContent="{helpers:Localize Key=Settings_Enabled}"
                                          OffContent="{helpers:Localize Key=Settings_Disabled}" />
                        </controls:SettingsCard>

                        <controls:SettingsCard>
                            <controls:SettingsCard.Header>
                                <TextBlock Text="{helpers:Localize Key=Settings_AntiAgingEight}" />
                            </controls:SettingsCard.Header>
                            <controls:SettingsCard.Description>
                                <TextBlock Text="{helpers:Localize Key=Settings_AntiAgingEightDesc}" TextWrapping="Wrap" />
                            </controls:SettingsCard.Description>
                            <ToggleSwitch IsOn="{Binding AntiAgingEightEnabled, Mode=TwoWay}"
                                          OnContent="{helpers:Localize Key=Settings_Enabled}"
                                          OffContent="{helpers:Localize Key=Settings_Disabled}" />
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <!-- Weight Tracking Section -->
                <TextBlock Text="{helpers:Localize Key=Settings_WeightTracking}"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           Margin="1,30,0,6" />

                <controls:SettingsExpander IsExpanded="{Binding WeightTrackingEnabled, Mode=OneWay}">
                    <controls:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE8CB;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </controls:SettingsExpander.HeaderIcon>
                    <controls:SettingsExpander.Header>
                        <TextBlock Text="{helpers:Localize Key=Settings_WeightTracking}" />
                    </controls:SettingsExpander.Header>
                    <controls:SettingsExpander.Description>
                        <TextBlock Text="{helpers:Localize Key=Settings_WeightTrackingDesc}" />
                    </controls:SettingsExpander.Description>
                    <ToggleSwitch IsOn="{Binding WeightTrackingEnabled, Mode=TwoWay}"
                                  OnContent="{helpers:Localize Key=Settings_Enabled}"
                                  OffContent="{helpers:Localize Key=Settings_Disabled}" />

                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard>
                            <controls:SettingsCard.Header>
                                <TextBlock Text="{helpers:Localize Key=Settings_GoalWeight}" />
                            </controls:SettingsCard.Header>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox Text="{Binding GoalWeightText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="{helpers:Localize Key=Settings_Optional}"
                                         Width="120"
                                         InputScope="Number" />
                                <TextBlock Text="{Binding WeightUnit}"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </controls:SettingsCard>

                        <controls:SettingsCard>
                            <controls:SettingsCard.Header>
                                <TextBlock Text="{helpers:Localize Key=Settings_Height}" />
                            </controls:SettingsCard.Header>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox Text="{Binding HeightText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="{helpers:Localize Key=Settings_Optional}"
                                         Width="120"
                                         InputScope="Number" />
                                <TextBlock Text="{Binding HeightUnit}"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <!-- Units Section -->
                <TextBlock Text="{helpers:Localize Key=Settings_Units}"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           Margin="1,30,0,6" />

                <controls:SettingsCard>
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE8AB;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </controls:SettingsCard.HeaderIcon>
                    <controls:SettingsCard.Header>
                        <TextBlock Text="{helpers:Localize Key=Settings_UseMetric}" />
                    </controls:SettingsCard.Header>
                    <controls:SettingsCard.Description>
                        <TextBlock Text="{helpers:Localize Key=Settings_UnitsDesc}" />
                    </controls:SettingsCard.Description>
                    <ToggleSwitch IsOn="{Binding UseMetricUnits, Mode=TwoWay}"
                                  OnContent="{helpers:Localize Key=Settings_Metric}"
                                  OffContent="{helpers:Localize Key=Settings_Imperial}" />
                </controls:SettingsCard>

                <!-- Appearance Section -->
                <TextBlock Text="{helpers:Localize Key=Settings_Appearance}"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           Margin="1,30,0,6" />

                <controls:SettingsCard>
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE790;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </controls:SettingsCard.HeaderIcon>
                    <controls:SettingsCard.Header>
                        <TextBlock Text="{helpers:Localize Key=Settings_Theme}" />
                    </controls:SettingsCard.Header>
                    <controls:SettingsCard.Description>
                        <TextBlock Text="{helpers:Localize Key=Settings_AppearanceDesc}" />
                    </controls:SettingsCard.Description>
                    <ComboBox ItemsSource="{Binding ThemeOptions}"
                              SelectedIndex="{Binding SelectedThemeIndex, Mode=TwoWay}"
                              MinWidth="200" />
                </controls:SettingsCard>

                <controls:SettingsCard>
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xF2B7;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </controls:SettingsCard.HeaderIcon>
                    <controls:SettingsCard.Header>
                        <TextBlock Text="{helpers:Localize Key=Settings_Language}" />
                    </controls:SettingsCard.Header>
                    <ComboBox ItemsSource="{Binding LanguageOptions}"
                              SelectedIndex="{Binding SelectedLanguageIndex, Mode=TwoWay}"
                              MinWidth="200" />
                </controls:SettingsCard>

                <TextBlock Text="{helpers:Localize Key=Settings_RestartRequired}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           Visibility="{Binding ShowRestartMessage}"
                           Margin="1,4,0,0" />

                <!-- Data Management Section -->
                <TextBlock Text="{helpers:Localize Key=Settings_DataManagement}"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           Margin="1,30,0,6" />

                <controls:SettingsExpander IsExpanded="False">
                    <controls:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xEBC4;" FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                    </controls:SettingsExpander.HeaderIcon>
                    <controls:SettingsExpander.Header>
                        <TextBlock Text="{helpers:Localize Key=Settings_DataManagement}" />
                    </controls:SettingsExpander.Header>
                    <controls:SettingsExpander.Description>
                        <TextBlock Text="{helpers:Localize Key=Settings_DataManagementDesc}" />
                    </controls:SettingsExpander.Description>

                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard>
                            <controls:SettingsCard.Header>
                                <TextBlock Text="{helpers:Localize Key=Settings_Export}" />
                            </controls:SettingsCard.Header>
                            <controls:SettingsCard.Description>
                                <TextBlock Text="{helpers:Localize Key=Settings_ExportDesc}" TextWrapping="Wrap" />
                            </controls:SettingsCard.Description>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="{helpers:Localize Key=Settings_ExportToJson}"
                                        Command="{Binding ExportToJsonCommand}"
                                        Style="{StaticResource AccentButtonStyle}" />
                                <Button Content="{helpers:Localize Key=Settings_ExportToCsv}"
                                        Command="{Binding ExportToCsvCommand}" />
                            </StackPanel>
                        </controls:SettingsCard>

                        <controls:SettingsCard>
                            <controls:SettingsCard.Header>
                                <TextBlock Text="{helpers:Localize Key=Settings_Import}" />
                            </controls:SettingsCard.Header>
                            <controls:SettingsCard.Description>
                                <TextBlock Text="{helpers:Localize Key=Settings_ImportDesc}" TextWrapping="Wrap" />
                            </controls:SettingsCard.Description>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="{helpers:Localize Key=Settings_ImportFromJson}"
                                        Command="{Binding ImportFromJsonCommand}" />
                                <Button Content="{helpers:Localize Key=Settings_ImportFromCsv}"
                                        Command="{Binding ImportFromCsvCommand}" />
                            </StackPanel>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

            </StackPanel>
        </Grid>
    </ScrollViewer>

</Page>
