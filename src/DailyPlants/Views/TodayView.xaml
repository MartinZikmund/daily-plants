<Page
    x:Class="DailyPlants.Views.TodayView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:DailyPlants.Helpers"
    xmlns:local="using:DailyPlants.Views"
    xmlns:utu="using:Uno.Toolkit.UI"
    xmlns:vm="using:DailyPlants.ViewModels">

    <Page.Resources>
        <!--  Wide template: single-row 3-column layout  -->
        <DataTemplate x:Key="WideItemTemplate" x:DataType="vm:ChecklistItemViewModel">
            <Grid
                Padding="16,12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8"
                Tapped="Grid_Tapped">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Item Icon  -->
                <BitmapIcon
                    Grid.Column="0"
                    Width="32"
                    Height="32"
                    Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    ShowAsMonochrome="False"
                    UriSource="{Binding Item.IconPath, Converter={StaticResource StringToUriConverter}}" />

                <!--  Item Info  -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{Binding Item.Name}" />
                    <TextBlock
                        Margin="0,2,0,0"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        MaxLines="1"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{Binding Item.ServingSizeExample}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <!--  Serving Controls  -->
                <StackPanel
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="6">

                    <!--  Minus Button (uses opacity, not disabled, to prevent click bubbling to parent)  -->
                    <Button
                        Width="32"
                        Height="32"
                        Padding="0"
                        Command="{Binding DecrementServingCommand}"
                        CornerRadius="16"
                        Opacity="{Binding ServingsCompleted, Converter={StaticResource GreaterThanZeroToOpacityConverter}}"
                        ToolTipService.ToolTip="{helpers:Localize Key=Today_DecreaseServing}">
                        <FontIcon FontSize="12" Glyph="&#xE738;" />
                    </Button>

                    <!--  Serving Count Badge - Progressive color based on completion  -->
                    <Border
                        MinWidth="48"
                        Padding="12,4"
                        Background="{Binding Progress, Converter={StaticResource ProgressToColorConverter}}"
                        CornerRadius="12">
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{Binding Progress, Converter={StaticResource ProgressToTextColorConverter}}"
                            Text="{Binding ServingsDisplayText}" />
                    </Border>

                    <!--  Plus Button  -->
                    <Button
                        Width="32"
                        Height="32"
                        Padding="0"
                        Command="{Binding IncrementServingCommand}"
                        CornerRadius="16"
                        Style="{StaticResource AccentButtonStyle}"
                        ToolTipService.ToolTip="{helpers:Localize Key=Today_IncreaseServing}">
                        <FontIcon
                            FontSize="12"
                            Foreground="Black"
                            Glyph="&#xE710;" />
                    </Button>

                    <!--  Info Button  -->
                    <Button
                        Width="32"
                        Height="32"
                        Padding="0"
                        Command="{Binding ShowItemDetailCommand}"
                        CornerRadius="16"
                        ToolTipService.ToolTip="{helpers:Localize Key=Today_MoreInfo}">
                        <FontIcon FontSize="12" Glyph="&#xE946;" />
                    </Button>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!--  Narrow template: 3-row layout, icon spans all rows  -->
        <DataTemplate x:Key="NarrowItemTemplate" x:DataType="vm:ChecklistItemViewModel">
            <Grid
                Padding="16,12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8"
                Tapped="Grid_Tapped">
                <StackPanel>

                    <!--  Icon + Name  -->
                    <StackPanel
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="8">
                        <BitmapIcon
                            Width="24"
                            Height="24"
                            VerticalAlignment="Center"
                            ShowAsMonochrome="False"
                            UriSource="{Binding Item.IconPath, Converter={StaticResource StringToUriConverter}}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Text="{Binding Item.Name}" />
                    </StackPanel>

                    <!--  Serving size description  -->
                    <TextBlock
                        Margin="0,2,0,0"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{Binding Item.ServingSizeExample}"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />

                    <!--  Serving Controls  -->
                    <StackPanel
                        Margin="0,6,0,0"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="6">

                        <!--  Minus Button (uses opacity, not disabled, to prevent click bubbling to parent)  -->
                        <Button
                            Width="32"
                            Height="32"
                            Padding="0"
                            Command="{Binding DecrementServingCommand}"
                            CornerRadius="16"
                            Opacity="{Binding ServingsCompleted, Converter={StaticResource GreaterThanZeroToOpacityConverter}}"
                            ToolTipService.ToolTip="{helpers:Localize Key=Today_DecreaseServing}">
                            <FontIcon FontSize="12" Glyph="&#xE738;" />
                        </Button>

                        <!--  Serving Count Badge - Progressive color based on completion  -->
                        <Border
                            MinWidth="48"
                            Padding="12,4"
                            Background="{Binding Progress, Converter={StaticResource ProgressToColorConverter}}"
                            CornerRadius="12">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="{Binding Progress, Converter={StaticResource ProgressToTextColorConverter}}"
                                Text="{Binding ServingsDisplayText}" />
                        </Border>

                        <!--  Plus Button  -->
                        <Button
                            Width="32"
                            Height="32"
                            Padding="0"
                            Command="{Binding IncrementServingCommand}"
                            CornerRadius="16"
                            Style="{StaticResource AccentButtonStyle}"
                            ToolTipService.ToolTip="{helpers:Localize Key=Today_IncreaseServing}">
                            <FontIcon
                                FontSize="12"
                                Foreground="Black"
                                Glyph="&#xE710;" />
                        </Button>

                        <!--  Info Button  -->
                        <Button
                            Width="32"
                            Height="32"
                            Padding="0"
                            Command="{Binding ShowItemDetailCommand}"
                            CornerRadius="16"
                            ToolTipService.ToolTip="{helpers:Localize Key=Today_MoreInfo}">
                            <FontIcon FontSize="12" Glyph="&#xE946;" />
                        </Button>

                    </StackPanel>

                </StackPanel>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="ChecklistList.ItemTemplate" Value="{StaticResource NarrowItemTemplate}" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="500" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="ChecklistList.ItemTemplate" Value="{StaticResource WideItemTemplate}" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <!--  Date Navigation Header  -->
        <Grid
            Grid.Row="0"
            Padding="16,16,16,8"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="0"
                Width="40"
                Height="40"
                Padding="0"
                Command="{Binding GoToPreviousDayCommand}"
                CornerRadius="20"
                ToolTipService.ToolTip="{helpers:Localize Key=Today_PreviousDay}">
                <FontIcon FontSize="16" Glyph="&#xE76B;" />
            </Button>

            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <!--  Date text with calendar flyout  -->
                <Button
                    x:Name="DatePickerButton"
                    Padding="8,4"
                    HorizontalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    ToolTipService.ToolTip="{helpers:Localize Key=Today_PickDate}">
                    <TextBlock
                        HorizontalAlignment="Center"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        Text="{Binding DateDisplayText}"
                        TextAlignment="Center" />
                    <Button.Flyout>
                        <Flyout x:Name="DatePickerFlyout" Placement="Bottom">
                            <CalendarView
                                x:Name="CalendarView"
                                MaxDate="{x:Bind ViewModel.MaxSelectableDate, Mode=OneWay}"
                                SelectedDatesChanged="CalendarView_SelectedDatesChanged"
                                SelectionMode="Single" />
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <!--  Fixed-height row for relative day label or go-to-today button  -->
                <Grid Margin="0,2,0,0" Height="32">
                    <!--  Relative day label (Today/Yesterday)  -->
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource BodyTextBlockStyle}"
                        Text="{Binding RelativeDayText}"
                        TextAlignment="Center"
                        Visibility="{Binding ShowRelativeDay}" />
                    <!--  Go to today button (shown on other days)  -->
                    <Button
                        Margin="0"
                        Padding="12,4"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Command="{Binding GoToTodayCommand}"
                        Content="{helpers:Localize Key=Today_GoToToday}"
                        Visibility="{Binding ShowGoToToday}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource DefaultButtonStyle}" TargetType="Button">
                                <Setter Property="FontSize" Value="12" />
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </StackPanel>

            <Button
                Grid.Column="2"
                Width="40"
                Height="40"
                Padding="0"
                Command="{Binding GoToNextDayCommand}"
                CornerRadius="20"
                IsEnabled="{Binding CanGoToNextDay}"
                ToolTipService.ToolTip="{helpers:Localize Key=Today_NextDay}">
                <FontIcon FontSize="16" Glyph="&#xE76C;" />
            </Button>
        </Grid>

        <!--  Progress Bar  -->
        <Grid Grid.Row="1" Padding="16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ProgressBar
                Grid.Column="0"
                Height="12"
                Margin="0,0,16,0"
                CornerRadius="6"
                Maximum="1"
                Value="{Binding OverallProgress}" />

            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Text="{Binding ProgressText}" />
        </Grid>

        <!--  Checklist Items  -->
        <ListView
            x:Name="ChecklistList"
            Grid.Row="2"
            Padding="4,0,4,4"
            ItemTemplate="{StaticResource NarrowItemTemplate}"
            ItemsSource="{Binding Items}"
            SelectionMode="None">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Margin" Value="0,0,0,8" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <!--  Loading Indicator  -->
        <ProgressRing
            Grid.Row="2"
            Width="48"
            Height="48"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsActive="{Binding IsLoading}" />

        <!--  Empty State  -->
        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="{Binding ShowEmptyState}">
            <FontIcon
                FontSize="48"
                Glyph="&#xE71E;"
                Opacity="0.5" />
            <TextBlock
                Margin="0,12,0,4"
                Opacity="0.7"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="{helpers:Localize Key=Today_NoChecklists}" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource BodyTextBlockStyle}"
                Text="{helpers:Localize Key=Today_EnableChecklist}" />
        </StackPanel>
    </Grid>

</Page>
