<Page x:Class="DailyPlants.Views.AchievementsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="using:DailyPlants.Converters"
      xmlns:vm="using:DailyPlants.ViewModels"
      NavigationCacheMode="Required"
      xmlns:helpers="using:DailyPlants.Helpers">

    <Page.Resources>
        <converters:HexToBrushConverter x:Key="HexToBrushConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0"
              Padding="16"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding ProgressText}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <Border Grid.Column="1"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    CornerRadius="20"
                    Padding="16,8"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE735;" FontSize="20" Foreground="White" />
                    <TextBlock Text="{Binding EarnedCount}"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="White" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Achievement List -->
        <ScrollViewer Grid.Row="1" Padding="16">
            <ItemsRepeater ItemsSource="{Binding AchievementGroups}">
                <ItemsRepeater.Layout>
                    <StackLayout Spacing="24" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:AchievementGroupViewModel">
                        <StackPanel>
                            <!-- Group Header -->
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                                <FontIcon Glyph="{Binding TypeIcon}" FontSize="20"
                                          Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                                <TextBlock Text="{Binding TypeName}"
                                           Style="{StaticResource SubtitleTextBlockStyle}" />
                            </StackPanel>

                            <!-- Achievements in Group -->
                            <ItemsRepeater ItemsSource="{Binding Achievements}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="8" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:AchievementViewModel">
                                        <Grid Padding="16"
                                              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                              CornerRadius="8"
                                              Opacity="{Binding Opacity}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Achievement Icon -->
                                            <Border Grid.Column="0"
                                                    Width="48" Height="48"
                                                    CornerRadius="24"
                                                    Background="{Binding BadgeColor, Converter={StaticResource HexToBrushConverter}}"
                                                    Margin="0,0,16,0">
                                                <FontIcon Glyph="{Binding IconGlyph}"
                                                          FontSize="24"
                                                          Foreground="White"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                            </Border>

                                            <!-- Achievement Info -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           Style="{StaticResource BodyStrongTextBlockStyle}" />
                                                <TextBlock Text="{Binding Description}"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,2,0,0" />

                                                <!-- Progress Bar (when not earned) -->
                                                <Grid Visibility="{Binding ShowProgress}"
                                                      Margin="0,8,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <ProgressBar Grid.Column="0"
                                                                 Value="{Binding Progress}"
                                                                 Maximum="1"
                                                                 Height="6"
                                                                 CornerRadius="3"
                                                                 Margin="0,0,8,0" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding ProgressText}"
                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                </Grid>
                                            </StackPanel>

                                            <!-- Earned Badge / Date -->
                                            <StackPanel Grid.Column="2"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Right">
                                                <FontIcon Glyph="&#xE73E;"
                                                          FontSize="24"
                                                          Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                                          Visibility="{Binding IsEarned}"
                                                          HorizontalAlignment="Center" />
                                                <TextBlock Text="{Binding EarnedAtText}"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           Visibility="{Binding IsEarned}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,4,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>

        <!-- Loading Indicator -->
        <ProgressRing Grid.Row="1"
                      IsActive="{Binding IsLoading}"
                      Width="48" Height="48"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />

        <!-- Empty State -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding AchievementGroups.Count, Converter={StaticResource EmptyToVisibleConverter}}">
            <FontIcon Glyph="&#xE735;" FontSize="48" Opacity="0.5" />
            <TextBlock Text="{helpers:Localize Key=Achievements_Empty}"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,12,0,0"
                       Opacity="0.7" />
        </StackPanel>
    </Grid>

</Page>
