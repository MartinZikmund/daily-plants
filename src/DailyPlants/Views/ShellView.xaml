<Page x:Class="DailyPlants.Views.ShellView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:DailyPlants.Views"
      xmlns:controls="using:DailyPlants.Controls"
      xmlns:helpers="using:DailyPlants.Helpers"
      xmlns:toolkit="using:Uno.UI.Toolkit"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid toolkit:VisibleBoundsPadding.PaddingMask="All">
        <NavigationView x:Name="NavView"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        AlwaysShowHeader="False"
                        PaneDisplayMode="Auto"
                        CompactModeThresholdWidth="500"
                        SelectionChanged="NavView_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="{helpers:Localize Key=Nav_Diary}" Tag="Diary">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="{helpers:Localize Key=Nav_Statistics}" Tag="Statistics">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D9;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="AchievementsNavItem"
                                    Content="{helpers:Localize Key=Nav_Achievements}"
                                    Tag="Achievements">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE734;" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.InfoBadge>
                        <InfoBadge x:Name="AchievementsBadge"
                                   Value="0"
                                   Visibility="Collapsed" />
                    </NavigationViewItem.InfoBadge>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="{helpers:Localize Key=Nav_Settings}" Tag="Settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="{helpers:Localize Key=Nav_About}" Tag="About">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE946;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Grid>
                <Frame x:Name="ContentFrame" MaxWidth="1024" />

                <Grid
                    Height="46"
                    x:Name="TitleBarOuter"
                    Padding="0,0"
                    Background="#00000000"
                    VerticalAlignment="Top"
                    ColumnSpacing="16"
                    Visibility="{x:Bind HasCustomTitleBar}">

                    <Grid Margin="0,0,0,0" x:Name="DraggableTitleBar">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                            <Image Source="ms-appx:///Assets/Svg/applogo.svg" Width="16" />
                            <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="Daily Plants" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>

        </NavigationView>

        <!-- Achievement Notification Popup -->
        <controls:AchievementNotification x:Name="AchievementNotification" />

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="TitleBarOuter.Padding" Value="48,0,0,0" />
                        <Setter Target="ContentFrame.Margin" Value="0,48,0,0" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="500" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="TitleBarOuter.Padding" Value="0,0,0,0" />
                        <Setter Target="ContentFrame.Margin" Value="56,44,56,0" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>

</Page>
