<Application x:Class="DailyDozen.App"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:converters="using:DailyDozen.Converters">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- Load WinUI resources -->
        <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
        <!-- Load Uno Toolkit resources -->
        <ToolkitResources xmlns="using:Uno.Toolkit.UI" />
      </ResourceDictionary.MergedDictionaries>

      <!-- Converters -->
      <converters:BoolNegationConverter x:Key="BoolNegationConverter" />
      <converters:EmptyToVisibleConverter x:Key="EmptyToVisibleConverter" />
      <converters:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter" />
      <converters:GreaterThanZeroToVisibleConverter x:Key="GreaterThanZeroToVisibleConverter" />
      <converters:GreaterThanZeroToOpacityConverter x:Key="GreaterThanZeroToOpacityConverter" />
      <converters:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />
      <converters:ProgressToColorConverter x:Key="ProgressToColorConverter" />
      <converters:ProgressToTextColorConverter x:Key="ProgressToTextColorConverter" />
      <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />

      <!-- Green Theme Colors -->
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <Color x:Key="SystemAccentColor">#4CAF50</Color>
          <Color x:Key="SystemAccentColorLight1">#66BB6A</Color>
          <Color x:Key="SystemAccentColorLight2">#81C784</Color>
          <Color x:Key="SystemAccentColorLight3">#A5D6A7</Color>
          <Color x:Key="SystemAccentColorDark1">#43A047</Color>
          <Color x:Key="SystemAccentColorDark2">#388E3C</Color>
          <Color x:Key="SystemAccentColorDark3">#2E7D32</Color>
          <SolidColorBrush x:Key="AccentBrush" Color="#4CAF50" />
          <SolidColorBrush x:Key="AccentBrushLight" Color="#81C784" />
          <SolidColorBrush x:Key="AccentBrushDark" Color="#388E3C" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <Color x:Key="SystemAccentColor">#66BB6A</Color>
          <Color x:Key="SystemAccentColorLight1">#81C784</Color>
          <Color x:Key="SystemAccentColorLight2">#A5D6A7</Color>
          <Color x:Key="SystemAccentColorLight3">#C8E6C9</Color>
          <Color x:Key="SystemAccentColorDark1">#4CAF50</Color>
          <Color x:Key="SystemAccentColorDark2">#43A047</Color>
          <Color x:Key="SystemAccentColorDark3">#388E3C</Color>
          <SolidColorBrush x:Key="AccentBrush" Color="#66BB6A" />
          <SolidColorBrush x:Key="AccentBrushLight" Color="#A5D6A7" />
          <SolidColorBrush x:Key="AccentBrushDark" Color="#4CAF50" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>

    </ResourceDictionary>
  </Application.Resources>

</Application>
