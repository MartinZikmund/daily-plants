<Page x:Class="DailyDozen.Views.TodayPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:DailyDozen.Views"
      xmlns:vm="using:DailyDozen.ViewModels"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:helpers="using:DailyDozen.Helpers"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Date Navigation Header -->
        <Grid Grid.Row="0"
              Padding="16,16,16,8"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Command="{Binding GoToPreviousDayCommand}"
                    Width="40" Height="40"
                    CornerRadius="20"
                    Padding="0"
                    ToolTipService.ToolTip="{helpers:Localize Key=Today_PreviousDay}">
                <FontIcon Glyph="&#xE76B;" FontSize="16" />
            </Button>

            <StackPanel Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <!-- Date text with calendar flyout -->
                <Button x:Name="DatePickerButton"
                        HorizontalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="8,4"
                        ToolTipService.ToolTip="{helpers:Localize Key=Today_PickDate}">
                    <TextBlock Text="{Binding DateDisplayText}"
                               Style="{StaticResource SubtitleTextBlockStyle}" />
                    <Button.Flyout>
                        <Flyout x:Name="DatePickerFlyout" Placement="Bottom">
                            <CalendarView x:Name="CalendarView"
                                          SelectedDatesChanged="CalendarView_SelectedDatesChanged"
                                          MaxDate="{x:Bind ViewModel.MaxSelectableDate, Mode=OneWay}"
                                          SelectionMode="Single" />
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <Button Content="{helpers:Localize Key=Today_GoToToday}"
                        HorizontalAlignment="Center"
                        Margin="0,4,0,0"
                        Padding="12,4"
                        Command="{Binding GoToTodayCommand}"
                        Visibility="{Binding CanGoToNextDay}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                            <Setter Property="FontSize" Value="12" />
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <Button Grid.Column="2"
                    Command="{Binding GoToNextDayCommand}"
                    IsEnabled="{Binding CanGoToNextDay}"
                    Width="40" Height="40"
                    CornerRadius="20"
                    Padding="0"
                    ToolTipService.ToolTip="{helpers:Localize Key=Today_NextDay}">
                <FontIcon Glyph="&#xE76C;" FontSize="16" />
            </Button>
        </Grid>

        <!-- Progress Bar -->
        <Grid Grid.Row="1" Padding="16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ProgressBar Grid.Column="0"
                         Value="{Binding OverallProgress}"
                         Maximum="1"
                         Height="12"
                         CornerRadius="6"
                         Margin="0,0,16,0" />

            <TextBlock Grid.Column="1"
                       Text="{Binding ProgressText}"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                       VerticalAlignment="Center" />
        </Grid>

        <!-- Checklist Items -->
        <ScrollViewer Grid.Row="2" Padding="16,0,16,16">
            <ItemsRepeater ItemsSource="{Binding Items}">
                <ItemsRepeater.Layout>
                    <StackLayout Spacing="8" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:ChecklistItemViewModel">
                        <Grid Padding="16,12"
                              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                              CornerRadius="8"
                              PointerPressed="ItemCard_PointerPressed">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Completion Checkmark (visible when 100% complete) / Placeholder for alignment -->
                            <FontIcon Grid.Column="0"
                                       Glyph="&#xE73E;"
                                       FontSize="20"
                                       Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center"
                                       Opacity="{Binding IsComplete, Converter={StaticResource BoolToOpacityConverter}}" />

                            <!-- Item Info -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Item.Name}"
                                           Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="{Binding Item.ServingSizeExample}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="1"
                                           Margin="0,2,0,0" />
                            </StackPanel>

                            <!-- Serving Controls -->
                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        Spacing="6"
                                        VerticalAlignment="Center">

                                <!-- Minus Button -->
                                <Button Command="{Binding DecrementServingCommand}"
                                        Width="32" Height="32"
                                        CornerRadius="16"
                                        Padding="0"
                                        Opacity="{Binding ServingsCompleted, Converter={StaticResource GreaterThanZeroToOpacityConverter}}">
                                    <FontIcon Glyph="&#xE738;" FontSize="12" />
                                </Button>

                                <!-- Serving Count Badge - Progressive color based on completion -->
                                <Border Background="{Binding Progress, Converter={StaticResource ProgressToColorConverter}}"
                                        CornerRadius="12"
                                        Padding="12,4"
                                        MinWidth="48">
                                    <TextBlock Text="{Binding ServingsDisplayText}"
                                               Foreground="{Binding Progress, Converter={StaticResource ProgressToTextColorConverter}}"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               HorizontalAlignment="Center" />
                                </Border>

                                <!-- Plus Button -->
                                <Button Command="{Binding IncrementServingCommand}"
                                        Width="32" Height="32"
                                        CornerRadius="16"
                                        Padding="0"
                                        Style="{StaticResource AccentButtonStyle}">
                                    <FontIcon Glyph="&#xE710;" FontSize="12" Foreground="Black" />
                                </Button>

                                <!-- Info Button -->
                                <Button Command="{Binding ShowItemDetailCommand}"
                                        Width="32" Height="32"
                                        CornerRadius="16"
                                        Padding="0">
                                    <FontIcon Glyph="&#xE946;" FontSize="12" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>

        <!-- Loading Indicator -->
        <ProgressRing Grid.Row="2"
                      IsActive="{Binding IsLoading}"
                      Width="48" Height="48"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />

        <!-- Empty State -->
        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding Items.Count, Converter={StaticResource EmptyToVisibleConverter}}">
            <FontIcon Glyph="&#xE71E;" FontSize="48" Opacity="0.5" />
            <TextBlock Text="{helpers:Localize Key=Today_NoChecklists}"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,12,0,4"
                       Opacity="0.7" />
            <TextBlock Text="{helpers:Localize Key=Today_EnableChecklist}"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
    </Grid>

</Page>
