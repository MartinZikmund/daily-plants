<Page x:Class="DailyDozen.Views.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:DailyDozen.Views"
      xmlns:helpers="using:DailyDozen.Helpers"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="16">
        <StackPanel Spacing="16"
                    MaxWidth="600"
                    HorizontalAlignment="Center">

            <!-- App Logo/Title -->
            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <FontIcon Glyph="&#xE8BA;"
                          FontSize="64"
                          Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                <TextBlock Text="{helpers:Localize Key=AppName}"
                           Style="{StaticResource TitleLargeTextBlockStyle}"
                           HorizontalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
                    <TextBlock Text="{helpers:Localize Key=About_Version}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="1.0"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- Description -->
            <TextBlock Text="{helpers:Localize Key=About_Description}"
                       TextWrapping="Wrap"
                       Style="{StaticResource BodyTextBlockStyle}"
                       TextAlignment="Center" />

            <!-- Links -->
            <StackPanel Spacing="8">
                <HyperlinkButton Content="{helpers:Localize Key=About_NutritionFacts}"
                                 NavigateUri="https://nutritionfacts.org"
                                 HorizontalAlignment="Center" />
                <TextBlock Text="{helpers:Localize Key=About_NutritionFactsDesc}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Credits -->
            <StackPanel Spacing="4" Margin="0,16,0,0">
                <TextBlock Text="{helpers:Localize Key=About_BuiltWith}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{helpers:Localize Key=About_CreditsDesc}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>

</Page>
