<Page x:Class="DailyDozen.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:DailyDozen.Views"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Padding="16" Spacing="24" MaxWidth="600">

            <!-- Header -->
            <TextBlock Text="Settings"
                       Style="{StaticResource TitleTextBlockStyle}" />

            <!-- Checklists Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Active Checklists"
                           Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Choose which checklists to track daily"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <ToggleSwitch Header="Daily Dozen"
                              IsOn="{Binding DailyDozenEnabled, Mode=TwoWay}"
                              OnContent="Enabled"
                              OffContent="Disabled"
                              Margin="0,8,0,0" />

                <ToggleSwitch Header="Twenty-One Tweaks"
                              IsOn="{Binding TwentyOneTweaksEnabled, Mode=TwoWay}"
                              OnContent="Enabled"
                              OffContent="Disabled" />

                <ToggleSwitch Header="Anti-Aging Eight"
                              IsOn="{Binding AntiAgingEightEnabled, Mode=TwoWay}"
                              OnContent="Enabled"
                              OffContent="Disabled" />
            </StackPanel>

            <Border Height="1"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!-- Weight Tracking Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Weight Tracking"
                           Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Track your weight over time"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <ToggleSwitch Header="Enable Weight Tracking"
                              IsOn="{Binding WeightTrackingEnabled, Mode=TwoWay}"
                              OnContent="Enabled"
                              OffContent="Disabled"
                              Margin="0,8,0,0" />

                <!-- Goal Weight and Height (visible when weight tracking is enabled) -->
                <StackPanel Spacing="12"
                            Visibility="{Binding WeightTrackingEnabled}"
                            Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox Header="Goal Weight"
                                 Text="{Binding GoalWeightText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Optional"
                                 Width="120"
                                 InputScope="Number" />
                        <TextBlock Text="{Binding WeightUnit}"
                                   VerticalAlignment="Bottom"
                                   Margin="0,0,0,10"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox Header="Height (for BMI)"
                                 Text="{Binding HeightText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Optional"
                                 Width="120"
                                 InputScope="Number" />
                        <TextBlock Text="{Binding HeightUnit}"
                                   VerticalAlignment="Bottom"
                                   Margin="0,0,0,10"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <Border Height="1"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!-- Units Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Units"
                           Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Choose your preferred measurement units"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <ToggleSwitch Header="Use Metric Units"
                              IsOn="{Binding UseMetricUnits, Mode=TwoWay}"
                              OnContent="Metric (kg, cm)"
                              OffContent="Imperial (lb, in)"
                              Margin="0,8,0,0" />
            </StackPanel>

            <Border Height="1"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!-- Appearance Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Appearance"
                           Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Customize how the app looks"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <ComboBox Header="Theme"
                          ItemsSource="{Binding ThemeOptions}"
                          SelectedIndex="{Binding SelectedThemeIndex, Mode=TwoWay}"
                          Margin="0,8,0,0"
                          MinWidth="200" />
            </StackPanel>

            <Border Height="1"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!-- Data Management Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Data Management"
                           Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Export or import your tracking data"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <!-- Export -->
                <TextBlock Text="Export"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           Margin="0,8,0,0" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Export to JSON"
                            Command="{Binding ExportToJsonCommand}"
                            Style="{StaticResource AccentButtonStyle}" />
                    <Button Content="Export to CSV"
                            Command="{Binding ExportToCsvCommand}" />
                </StackPanel>
                <TextBlock Text="JSON exports all data including settings. CSV exports daily entries only."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           TextWrapping="Wrap" />

                <!-- Import -->
                <TextBlock Text="Import"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           Margin="0,12,0,0" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Import from JSON"
                            Command="{Binding ImportFromJsonCommand}" />
                    <Button Content="Import from CSV"
                            Command="{Binding ImportFromCsvCommand}" />
                </StackPanel>
                <TextBlock Text="Import will merge with existing data. Duplicate entries will be overwritten."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>

</Page>
